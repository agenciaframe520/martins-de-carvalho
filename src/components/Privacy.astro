---
import BaseLayout from '../layouts/BaseLayout.astro';
import { EMAIL, type Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;

const content: Record<Lang, { title: string; metaDesc: string; sections: { h: string; p: string[] }[] }> = {
  pt: {
    title: 'Política de Privacidade — Martins de Carvalho',
    metaDesc: 'Saiba como a Martins de Carvalho coleta, usa e protege seus dados pessoais em conformidade com a LGPD.',
    sections: [
      {
        h: 'Dados que coletamos',
        p: [
          'Em conformidade com a Lei Geral de Proteção de Dados (Lei 13.709/2018 — LGPD), quando você preenche o formulário de contato do site, coletamos apenas as informações que você nos fornece voluntariamente:',
          '• Nome\n• Email\n• Mensagem (o conteúdo da sua mensagem)',
          'Não coletamos dados de navegação, cookies de rastreamento, analytics ou qualquer informação pessoal além do que você envia pelo formulário. Utilizamos apenas cookies essenciais para o funcionamento do site.',
        ],
      },
      {
        h: 'Base legal',
        p: [
          'A base legal para o tratamento dos seus dados pessoais é o seu consentimento (art. 7º, inciso I da LGPD), manifestado pelo envio voluntário do formulário de contato.',
        ],
      },
      {
        h: 'Como usamos seus dados',
        p: [
          'Seus dados são usados exclusivamente para responder à sua mensagem. Não compartilhamos, vendemos ou alugamos suas informações para terceiros.',
        ],
      },
      {
        h: 'Armazenamento',
        p: [
          'Seus dados ficam armazenados apenas pelo tempo necessário para atender sua solicitação, no máximo até 12 meses após o último contato. Você pode solicitar a exclusão a qualquer momento entrando em contato pelo mesmo email.',
        ],
      },
      {
        h: 'Seus direitos',
        p: [
          'Você tem direito a:',
          '• Saber quais dados temos sobre você\n• Solicitar a correção ou exclusão dos seus dados\n• Revogar seu consentimento a qualquer momento',
        ],
      },
      {
        h: 'Contato',
        p: [
          `Para exercer seus direitos ou tirar dúvidas sobre esta política, escreva para ${EMAIL}.`,
        ],
      },
    ],
  },
  de: {
    title: 'Datenschutzerklärung — Martins de Carvalho',
    metaDesc: 'Erfahren Sie, wie Martins de Carvalho Ihre personenbezogenen Daten in Übereinstimmung mit der brasilianischen Datenschutzgesetzgebung (LGPD) erhebt, nutzt und schützt.',
    sections: [
      {
        h: 'Welche Daten wir erheben',
        p: [
          'In Übereinstimmung mit dem brasilianischen Datenschutzgesetz (Lei Geral de Proteção de Dados — LGPD, Gesetz 13.709/2018) erheben wir, wenn Sie das Kontaktformular auf unserer Website ausfüllen, nur die Informationen, die Sie uns freiwillig zur Verfügung stellen:',
          '• Name\n• E-Mail\n• Nachricht (der Inhalt Ihrer Nachricht)',
          'Wir erheben keine Browserdaten, Tracking-Cookies, Analytics oder persönliche Informationen über das hinaus, was Sie über das Formular senden. Wir verwenden nur technisch notwendige Cookies.',
        ],
      },
      {
        h: 'Rechtsgrundlage',
        p: [
          'Rechtsgrundlage für die Verarbeitung Ihrer personenbezogenen Daten ist Ihre Einwilligung (Art. 7, Abs. I der LGPD), die durch das freiwillige Absenden des Kontaktformulars erteilt wird.',
        ],
      },
      {
        h: 'Wie wir Ihre Daten verwenden',
        p: [
          'Ihre Daten werden ausschließlich zur Beantwortung Ihrer Nachricht verwendet. Wir geben, verkaufen oder vermieten Ihre Informationen nicht an Dritte weiter.',
        ],
      },
      {
        h: 'Speicherung',
        p: [
          'Ihre Daten werden nur so lange gespeichert, wie es für die Bearbeitung Ihrer Anfrage erforderlich ist, maximal 12 Monate nach dem letzten Kontakt. Sie können jederzeit die Löschung per E-Mail anfordern.',
        ],
      },
      {
        h: 'Ihre Rechte',
        p: [
          'Sie haben das Recht:',
          '• Zu erfahren, welche Daten wir über Sie haben\\n• Die Berichtigung oder Löschung Ihrer Daten zu verlangen\\n• Ihre Einwilligung jederzeit zu widerrufen',
        ],
      },
      {
        h: 'Kontakt',
        p: [
          `Um Ihre Rechte auszuüben oder Fragen zu dieser Richtlinie zu stellen, schreiben Sie an ${EMAIL}.`,
        ],
      },
    ],
  },
  en: {
    title: 'Privacy Policy — Martins de Carvalho',
    metaDesc: 'Learn how Martins de Carvalho collects, uses and protects your personal data in compliance with Brazilian data protection law (LGPD).',
    sections: [
      {
        h: 'Data we collect',
        p: [
          'In compliance with the Brazilian General Data Protection Law (Lei 13.709/2018 — LGPD), when you fill out the contact form on our website, we collect only the information you voluntarily provide:',
          '• Name\n• Email\n• Message (the content of your message)',
          'We do not collect browsing data, tracking cookies, analytics or any personal information beyond what you submit through the form. We use only essential cookies for the website to function.',
        ],
      },
      {
        h: 'Legal basis',
        p: [
          'The legal basis for processing your personal data is your consent (Art. 7, I of the LGPD), given by voluntarily submitting the contact form.',
        ],
      },
      {
        h: 'How we use your data',
        p: [
          'Your data is used exclusively to respond to your message. We do not share, sell or rent your information to third parties.',
        ],
      },
      {
        h: 'Storage',
        p: [
          'Your data is stored only as long as necessary to address your request, up to a maximum of 12 months after the last contact. You may request deletion at any time by email.',
        ],
      },
      {
        h: 'Your rights',
        p: [
          'You have the right to:',
          '• Know what data we hold about you\\n• Request correction or deletion of your data\\n• Withdraw your consent at any time',
        ],
      },
      {
        h: 'Contact',
        p: [
          `To exercise your rights or ask questions about this policy, write to ${EMAIL}.`,
        ],
      },
    ],
  },
  es: {
    title: 'Política de Privacidad — Martins de Carvalho',
    metaDesc: 'Conozca cómo Martins de Carvalho recopila, utiliza y protege sus datos personales en cumplimiento de la legislación brasileña de protección de datos (LGPD).',
    sections: [
      {
        h: 'Datos que recopilamos',
        p: [
          'En cumplimiento de la Ley General de Protección de Datos de Brasil (Ley 13.709/2018 — LGPD), cuando completa el formulario de contacto en nuestro sitio web, recopilamos solo la información que usted proporciona voluntariamente:',
          '• Nombre\n• Email\n• Mensaje (el contenido de su mensaje)',
          'No recopilamos datos de navegación, cookies de rastreo, analytics ni información personal más allá de lo que envía a través del formulario. Utilizamos solo cookies esenciales para el funcionamiento del sitio.',
        ],
      },
      {
        h: 'Base legal',
        p: [
          'La base legal para el tratamiento de sus datos personales es su consentimiento (art. 7, inciso I de la LGPD), otorgado mediante el envío voluntario del formulario de contacto.',
        ],
      },
      {
        h: 'Cómo usamos sus datos',
        p: [
          'Sus datos se utilizan exclusivamente para responder a su mensaje. No compartimos, vendemos ni alquilamos su información a terceros.',
        ],
      },
      {
        h: 'Almacenamiento',
        p: [
          'Sus datos se almacenan solo durante el tiempo necesario para atender su solicitud, como máximo hasta 12 meses después del último contacto. Puede solicitar la eliminación en cualquier momento por correo electrónico.',
        ],
      },
      {
        h: 'Sus derechos',
        p: [
          'Usted tiene derecho a:',
          '• Saber qué datos tenemos sobre usted\\n• Solicitar la corrección o eliminación de sus datos\\n• Revocar su consentimiento en cualquier momento',
        ],
      },
      {
        h: 'Contacto',
        p: [
          `Para ejercer sus derechos o hacer preguntas sobre esta política, escriba a ${EMAIL}.`,
        ],
      },
    ],
  },
};

const c = content[lang];
---

<BaseLayout lang={lang} metaTitle={c.title} metaDescription={c.metaDesc}>
  <article class="section-y">
    <div class="container-md max-w-2xl">
      <h1 class="font-display text-primary" style="font-size: var(--text-h1);">{c.title.split(' — ')[0]}</h1>
      <p class="text-text-secondary text-small mt-1 mb-8">Martins de Carvalho</p>

      {c.sections.map((s) => (
        <section class="mb-8 last:mb-0">
          <h2 class="font-display text-primary mb-3" style="font-size: var(--text-h3);">{s.h}</h2>
          {s.p.map((para) => (
            <p class="text-text-secondary mb-3 whitespace-pre-line">{para}</p>
          ))}
        </section>
      ))}
    </div>
  </article>
</BaseLayout>