---
import { PUBLICATIONS_URL, dict, type Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = dict[lang];
---

<section id="publicacoes" class="section-y">
  <div class="container-md max-w-3xl">
    <span class="block w-10 h-0.5 bg-accent mb-5 reveal" aria-hidden="true"></span>
    <h2 class="font-display text-primary mb-3 reveal" style="font-size: var(--text-h1);">{t.publicacoes.heading}</h2>
    <p class="text-text-secondary max-w-2xl mb-8 reveal">{t.publicacoes.intro}</p>
    <a
      href={PUBLICATIONS_URL}
      target="_blank"
      rel="noopener"
      class="btn-outline reveal"
    >
      {t.publicacoes.linkLabel}
    </a>
  </div>
</section>