---
import Logo from './Logo.astro';
import { dict, type Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = dict[lang];
---

<section id="top" class="section-y flex flex-col items-center text-center relative overflow-hidden">
  <!-- Decorative diagonal echoing the logo -->
  <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
    <line x1="5" y1="95" x2="95" y2="5" stroke="var(--color-accent)" stroke-width="0.12" opacity="0.18" />
  </svg>

  <div class="container-md flex flex-col items-center gap-6 relative z-10">
    <span class="w-64 h-64 md:w-80 md:h-80 hero-reveal">
      <Logo variant="light" class="w-full h-full" />
    </span>

    <span class="block w-14 h-0.5 bg-accent hero-reveal" aria-hidden="true"></span>

    <p class="max-w-2xl text-text-primary text-base md:text-lg font-body hero-reveal" set:html={t.hero.tagline}>
    </p>

    <a href="#contato" class="btn-outline mt-2 hero-reveal">
      {t.hero.cta}
    </a>
  </div>

  <!-- Scroll cue -->
  <a href="#sobre" class="absolute bottom-6 left-1/2 scroll-cue block w-px h-10 bg-accent" aria-label="Scroll down">
  </a>
</section>