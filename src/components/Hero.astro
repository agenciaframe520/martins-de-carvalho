---
import Logo from './Logo.astro';
import { dict, type Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = dict[lang];
---

<section id="top" class="section-y flex flex-col items-center text-center relative">
  <div class="container-md flex flex-col items-center gap-6">
    <span class="w-64 h-64 md:w-80 md:h-80 hero-reveal">
      <Logo variant="light" class="w-full h-full" />
    </span>

    <span class="block w-14 h-0.5 bg-accent hero-reveal" aria-hidden="true"></span>

    <p class="max-w-xl text-text-primary text-base md:text-lg font-body hero-reveal">
      {t.hero.tagline.split('<br>')[0]}
    </p>

    <a href="#contato" class="btn-outline mt-2 hero-reveal">
      {t.hero.cta}
    </a>
  </div>

  <!-- Scroll cue -->
  <a href="#sobre" class="absolute bottom-6 left-1/2 scroll-cue block w-px h-10 bg-accent" aria-label="Scroll down">
  </a>
</section>