---
import { dict, type Lang } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = dict[lang];
---

<section id="sobre" class="section-y bg-background-alt">
  <div class="container-md max-w-3xl">
    <span class="block w-10 h-0.5 bg-accent mb-5 reveal" aria-hidden="true"></span>
    <h2 class="font-display text-primary mb-6 reveal" style="font-size: var(--text-h1);">{t.sobre.heading}</h2>
    <div class="space-y-5 text-lg leading-relaxed reveal">
      <p>{t.sobre.p1}</p>
      <p>{t.sobre.p2}</p>
    </div>
    {t.sobre.languages && <p class="text-text-secondary italic mt-6 reveal">{t.sobre.languages}</p>}
  </div>
</section>