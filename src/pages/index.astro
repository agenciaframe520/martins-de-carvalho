---
// Root redirect: Astro i18n should auto-redirect, this is fallback for static hosts.
return Astro.redirect('/pt/');
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/pt/" />
    <link rel="canonical" href="https://www.martinsdecarvalho.com.br/pt/" />
    <meta name="robots" content="noindex" />
    <title>Martins de Carvalho</title>
  </head>
  <body>
    <p>Redirecting to <a href="/pt/">/pt/</a></p>
  </body>
</html>